{
  "name": "better-scripts",
  "displayName": "Better Scripts",
  "description": "A beautiful replacement for the built-in npm scripts sidebar — supports npm, pnpm, bun, and yarn with auto-detection, rich icons, and one-click run/debug.",
  "version": "1.0.1",
  "publisher": "MeinhartThomas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-scripts/better-scripts"
  },
  "icon": "icons/extension-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/package.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Better Scripts",
      "properties": {
        "betterScripts.terminalBehavior": {
          "type": "string",
          "enum": [
            "reuse",
            "newTerminal"
          ],
          "default": "reuse",
          "enumDescriptions": [
            "Reuse an existing terminal for the same script",
            "Always create a new terminal"
          ],
          "description": "Controls whether to reuse an existing terminal or create a new one when running scripts."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "betterScripts",
          "name": "Better Scripts"
        }
      ]
    },
    "commands": [
      {
        "command": "betterScripts.runScript",
        "title": "Run Script",
        "icon": "$(play)"
      },
      {
        "command": "betterScripts.debugScript",
        "title": "Debug Script",
        "icon": "$(debug-alt)"
      },
      {
        "command": "betterScripts.openScript",
        "title": "Open in package.json",
        "icon": "$(go-to-file)"
      },
      {
        "command": "betterScripts.openPackageJson",
        "title": "Open package.json",
        "icon": "$(go-to-file)"
      },
      {
        "command": "betterScripts.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "betterScripts.openPackageJson",
          "when": "viewItem == packageJson",
          "group": "inline@1"
        },
        {
          "command": "betterScripts.openScript",
          "when": "viewItem == script",
          "group": "inline@1"
        },
        {
          "command": "betterScripts.debugScript",
          "when": "viewItem == script",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "command": "betterScripts.refresh",
          "when": "view == betterScripts",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "dev": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "bun run build && npx @vscode/vsce package --no-dependencies",
    "install:vscode": "bun run package && code --install-extension $(ls *.vsix | head -1)",
    "install:cursor": "bun run package && cursor --install-extension $(ls *.vsix | head -1)",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
